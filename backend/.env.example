NODE_ENV=development
HOST=0.0.0.0
PORT=4000
API_PREFIX=/api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/debug_bot_tgh
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=false
BODY_SIZE_LIMIT=1mb
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
AUTH_BCRYPT_ROUNDS=12
BOOKING_RESERVATION_MINUTES=15
BOOKING_SEARCH_DAYS=14
BOOKING_SLOT_INTERVAL_MINUTES=15
BOT_API_SECRET=change-me-bot-api-secret-min-16-chars
MAX_ACTIVE_RESERVATIONS_PER_USER=2
PAYMENT_MOCK_PROVIDER_ENABLED=true
PAYMENT_RETRY_COOLDOWN_SECONDS=60
WORKER_ENABLED=true
EMBEDDED_WORKERS_ENABLED=false
TELEGRAM_BOT_TOKEN=
