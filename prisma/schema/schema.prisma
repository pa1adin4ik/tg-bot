generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
  INVITED
  ARCHIVED
}

enum BookingStatus {
  PENDING
  AWAITING_PREPAYMENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
  EXPIRED
}

enum ReviewStatus {
  PENDING_MODERATION
  PUBLISHED
  HIDDEN
}

enum PaymentStatus {
  PENDING
  RESERVED
  AUTHORIZED
  CAPTURED
  FAILED
  CANCELED
  REFUNDED
  EXPIRED
}

enum PaymentKind {
  PREPAYMENT
  FULL
  REMAINING
  REFUND
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
  BANK_TRANSFER
}

enum PortfolioMediaType {
  IMAGE
  VIDEO
}

enum ScheduleType {
  WORKING_HOURS
  BLOCKED_TIME
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum TimeSlotStatus {
  AVAILABLE
  RESERVED
  BOOKED
  BLOCKED
  EXPIRED
}

enum NotificationChannel {
  TELEGRAM
  EMAIL
  SMS
  PUSH
  SYSTEM
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELED
  BOOKING_REMINDER
  PAYMENT_PENDING
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  REVIEW_REMINDER
  SCHEDULE_CHANGED
  SYSTEM_ALERT
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
  CANCELED
}

enum CurrencyCode {
  USD
  EUR
  UZS
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  telegramId   String?   @unique
  email        String?   @unique
  phone        String?   @unique
  username     String?
  firstName    String
  lastName     String?
  avatarUrl    String?
  locale       String?   @db.VarChar(10)
  timezone     String?   @db.VarChar(64)
  status       UserStatus @default(ACTIVE)
  lastSeenAt   DateTime?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  adminProfile   Admin?
  masterProfile  Master?
  bookings       Booking[]      @relation("CustomerBookings")
  reviews        Review[]
  payments       Payment[]
  notifications  Notification[]

  @@index([status, deletedAt])
  @@index([createdAt])
}

model Admin {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @db.Uuid
  roleId       String   @db.Uuid
  passwordHash String
  tokenVersion Int      @default(0)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  passwordChangedAt DateTime?
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  role             Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdBookings  Booking[] @relation("AdminCreatedBookings")

  @@index([roleId, isActive, deletedAt])
}

model Role {
  id           String   @id @default(uuid()) @db.Uuid
  code         String   @unique
  name         String
  description  String?
  permissions  String[] @default([])
  isSystem     Boolean  @default(false)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  admins Admin[]

  @@index([isSystem, deletedAt])
}

model Service {
  id               String        @id @default(uuid()) @db.Uuid
  categoryId       String        @db.Uuid
  name             String
  slug             String        @unique
  description      String?
  durationMinutes  Int
  price            Decimal       @db.Decimal(12, 2)
  currency         CurrencyCode  @default(UZS)
  prepaymentRequired Boolean     @default(false)
  prepaymentAmount  Decimal?      @db.Decimal(12, 2)
  sortOrder        Int           @default(0)
  isActive         Boolean       @default(true)
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  category ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  masters  Master[]
  bookings Booking[]

  @@index([categoryId, isActive, deletedAt])
  @@index([isActive, deletedAt])
  @@index([name])
}

model ServiceCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  services Service[]

  @@index([isActive, deletedAt, sortOrder])
  @@index([name])
}

model Master {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @unique @db.Uuid
  bio              String?
  experienceYears  Int?
  ratingAvg        Decimal   @default(0) @db.Decimal(3, 2)
  reviewCount      Int       @default(0)
  isVisible        Boolean   @default(true)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  services       Service[]
  bookings       Booking[]
  reviews        Review[]
  portfolioWorks PortfolioWork[]
  schedules      Schedule[]
  timeSlots      TimeSlot[]

  @@index([isVisible, deletedAt])
}

model Booking {
  id                     String         @id @default(uuid()) @db.Uuid
  userId                 String         @db.Uuid
  masterId               String         @db.Uuid
  serviceId              String         @db.Uuid
  timeSlotId             String?        @db.Uuid
  createdByAdminId       String?        @db.Uuid
  status                 BookingStatus  @default(PENDING)
  startAt                DateTime
  endAt                  DateTime
  totalPrice             Decimal        @db.Decimal(12, 2)
  prepaymentAmount       Decimal?       @db.Decimal(12, 2)
  currency               CurrencyCode   @default(UZS)
  notes                  String?
  cancelReason           String?
  reservationExpiresAt   DateTime?
  confirmedAt            DateTime?
  canceledAt             DateTime?
  completedAt            DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  user           User        @relation("CustomerBookings", fields: [userId], references: [id], onDelete: Restrict)
  master         Master      @relation(fields: [masterId], references: [id], onDelete: Restrict)
  service        Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  timeSlot       TimeSlot?   @relation(fields: [timeSlotId], references: [id], onDelete: SetNull)
  createdByAdmin Admin?      @relation("AdminCreatedBookings", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  payments       Payment[]
  review         Review?
  notifications  Notification[]

  @@index([userId, createdAt])
  @@index([masterId, startAt, endAt])
  @@index([serviceId, startAt])
  @@index([status, reservationExpiresAt])
  @@index([timeSlotId])
}

model Review {
  id           String       @id @default(uuid()) @db.Uuid
  bookingId    String       @unique @db.Uuid
  userId       String       @db.Uuid
  masterId     String       @db.Uuid
  rating       Int
  comment      String?
  status       ReviewStatus @default(PENDING_MODERATION)
  moderatedAt  DateTime?
  moderatedByAdminId String? @db.Uuid
  rejectReason String?
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  master  Master  @relation(fields: [masterId], references: [id], onDelete: Restrict)

  @@index([masterId, status, createdAt])
  @@index([userId, createdAt])
}

model Payment {
  id                 String         @id @default(uuid()) @db.Uuid
  bookingId          String         @db.Uuid
  userId             String         @db.Uuid
  kind               PaymentKind
  method             PaymentMethod
  status             PaymentStatus  @default(PENDING)
  amount             Decimal        @db.Decimal(12, 2)
  currency           CurrencyCode   @default(UZS)
  externalReference  String?        @unique
  reservedAt         DateTime?
  authorizedAt       DateTime?
  capturedAt         DateTime?
  failedAt           DateTime?
  expiresAt          DateTime?
  metadata           Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([bookingId, status, kind])
  @@index([userId, createdAt])
  @@index([status, expiresAt])
}

model PortfolioCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  works PortfolioWork[]

  @@index([sortOrder])
}

model PortfolioWork {
  id           String             @id @default(uuid()) @db.Uuid
  masterId     String             @db.Uuid
  categoryId   String?            @db.Uuid
  title        String
  description  String?
  caption      String?
  mediaUrl     String
  mediaType    PortfolioMediaType
  sortOrder    Int                @default(0)
  isFeatured   Boolean            @default(false)
  isPublished  Boolean            @default(true)
  deletedAt    DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  master   Master             @relation(fields: [masterId], references: [id], onDelete: Cascade)
  category PortfolioCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([masterId, isPublished, deletedAt])
  @@index([masterId, isFeatured, deletedAt])
  @@index([categoryId])
  @@index([sortOrder])
}

model Schedule {
  id           String        @id @default(uuid()) @db.Uuid
  masterId     String        @db.Uuid
  type         ScheduleType  @default(WORKING_HOURS)
  dayOfWeek    DayOfWeek?
  specificDate DateTime?     @db.Date
  startMinute  Int
  endMinute    Int
  timezone     String        @db.VarChar(64)
  isRecurring  Boolean       @default(true)
  isActive     Boolean       @default(true)
  validFrom    DateTime?     @db.Date
  validTo      DateTime?     @db.Date
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  master    Master     @relation(fields: [masterId], references: [id], onDelete: Cascade)
  timeSlots TimeSlot[]

  @@index([masterId, type, isActive, deletedAt])
  @@index([masterId, dayOfWeek, validFrom, validTo])
  @@index([masterId, specificDate])
}

model TimeSlot {
  id             String         @id @default(uuid()) @db.Uuid
  masterId       String         @db.Uuid
  scheduleId     String?        @db.Uuid
  status         TimeSlotStatus @default(AVAILABLE)
  startAt        DateTime
  endAt          DateTime
  reservedUntil  DateTime?
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  master    Master    @relation(fields: [masterId], references: [id], onDelete: Cascade)
  schedule  Schedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  bookings  Booking[]

  @@unique([masterId, startAt, endAt])
  @@index([masterId, status, startAt])
  @@index([scheduleId])
  @@index([reservedUntil])
}

model Notification {
  id              String              @id @default(uuid()) @db.Uuid
  userId          String              @db.Uuid
  bookingId       String?             @db.Uuid
  type            NotificationType
  channel         NotificationChannel
  status          NotificationStatus  @default(PENDING)
  title           String?
  message         String
  payload         Json?
  idempotencyKey  String?             @unique
  attemptCount    Int                 @default(0)
  maxAttempts     Int                 @default(5)
  nextAttemptAt   DateTime?
  lastError       String?
  sentAt          DateTime?
  readAt          DateTime?
  failedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([bookingId, channel])
  @@index([type, status])
  @@index([status, nextAttemptAt])
}
