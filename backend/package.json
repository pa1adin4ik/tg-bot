{
  "name": "debug-bot-tgh-backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "worker": "node dist/workers/run.js",
    "test": "NODE_ENV=test jest",
    "test:integration": "NODE_ENV=test jest --config jest.integration.config.ts",
    "prisma:generate": "prisma generate --schema ../prisma/schema/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema ../prisma/schema/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema ../prisma/schema/schema.prisma",
    "prisma:studio": "prisma studio --schema ../prisma/schema/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.5.0",
    "pino": "^9.7.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.15.21",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "prisma": "^6.8.2",
    "supertest": "^7.1.1",
    "ts-jest": "^29.3.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
