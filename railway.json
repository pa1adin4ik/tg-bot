{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm --prefix bot ci && npm --prefix bot run build"
  },
  "deploy": {
    "startCommand": "npm --prefix bot run start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
